{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "{REPLACE: how-to title}",
  "description": "{REPLACE: short description}",
  "image": "{REPLACE: hero image URL}",
  "totalTime": "PT{REPLACE: minutes}M",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "{REPLACE: cost as string}"
  },
  "supply": [
    {"@type": "HowToSupply", "name": "{REPLACE: supply 1}"}
  ],
  "tool": [
    {"@type": "HowToTool", "name": "{REPLACE: tool 1}"}
  ],
  "step": [
    {
      "@type": "HowToStep",
      "name": "{REPLACE: step 1 title}",
      "text": "{REPLACE: step 1 detail}",
      "image": "{REPLACE: step 1 image URL}",
      "url": "{REPLACE: anchor URL with #step-1}"
    }
  ]
}
